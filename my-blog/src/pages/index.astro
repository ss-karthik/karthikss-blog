---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "home"
import TagButton from '../components/TagButton.astro';
import Button from '../components/Button.astro';
import MusicPlayer from '../components/MusicPlayer.jsx';
import music from '../music.json'
const earworm = music.earworms[0];
const allPosts = await Astro.glob('./posts/*.md');
const tags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())];
---

<BaseLayout title={title}>
	<div class="flex flex-wrap justify-center lg:grid grid-cols-4 lg:h-64">
		<div class="flex flex-col col-span-3">
			<div class="text-[#ebdbb2] bg-[#282828] m-2 p-4  rounded-2xl h-full">
				Hey there fellow humans! I am Karthik a.k.a. maniak. I am a CompSci student and I have a great fascination for tech. I also make videos on my YouTube channel. I am a noob (if I say so myself) in the software development space. I also am a great fan of music and would love to make my own music some day. This is my personal space where I talk about all kinds of things that I wish to communicate with the present and future world. So I hope you enjoy reading my thoughts!
			</div>
			<div class="flex gap-2 justify-around flex-wrap items-center text-[#ebdbb2] bg-[#282828] m-2 p-4  rounded-2xl">
				Find me at:
				<Button url="https://www.youtube.com/@Maniakss" title="YouTube" />
                <Button url="https://github.com/ss-karthik" title="GitHub" />
                <Button url="https://x.com/ssmaniak" title="Twitter" />
                <Button url="mailto:maniac.sskarthik@gmail.com" title="E-Mail" />
                <Button url="https://karthikss.vercel.app" title="Portfolio" />
			</div>
		</div>
		<div class="text-[#ebdbb2] bg-[#282828] m-2 p-4 rounded-2xl col-span-1 min-w-48 min-h-48 col-span-1">
			<div>Current Earworm</div>
			<MusicPlayer earworm={earworm} client:load />
		</div>
	</div>

	<div class="flex justify-around items-center text-[#ebdbb2] bg-[#282828] m-2 p-4  rounded-2xl">
		<h1 class="text-2xl">Tags: </h1>
		<div class="flex flex-wrap justify-center items-center gap-5 py-5">
			{tags.map((tag) => (
				<TagButton url={tag} title={tag}/>
			))}
		</div>
	</div>


</BaseLayout>
